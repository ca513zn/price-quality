generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubmissionStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  password         String
  role             Role              @default(USER)
  votes            Vote[]
  submissions      BrandSubmission[] @relation("SubmittedBy")
  reviewedSubmissions BrandSubmission[] @relation("ReviewedBy")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  brands      Brand[]  @relation("BrandCategories")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Brand {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  logoUrl     String?
  products    Product[]
  categories  Category[] @relation("BrandCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  imageUrl         String?
  brand            Brand    @relation(fields: [brandId], references: [id])
  brandId          String
  votes            Vote[]
  avgPriceScore    Float    @default(0)
  avgQualityScore  Float    @default(0)
  totalVotes       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([brandId])
  @@index([slug])
}

model Vote {
  id           String   @id @default(cuid())
  product      Product  @relation(fields: [productId], references: [id])
  productId    String
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  priceScore   Int      // 1-10
  qualityScore Int      // 1-10
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

model BrandSubmission {
  id              String           @id @default(cuid())
  name            String
  slug            String
  description     String?
  websiteUrl      String?
  categories      String[]         // Category names proposed by submitter
  status          SubmissionStatus @default(PENDING)
  submitter       User             @relation("SubmittedBy", fields: [submitterId], references: [id])
  submitterId     String
  reviewer        User?            @relation("ReviewedBy", fields: [reviewerId], references: [id])
  reviewerId      String?
  reviewNotes     String?
  rejectionReason String?
  promotedBrandId String?          // Links to Brand.id on approval
  duplicateOfId   String?          // Links to existing Brand.id if duplicate
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([submitterId])
  @@index([slug])
}
